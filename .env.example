# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
# For MongoDB Atlas, use: mongodb+srv://username:password@cluster-name.mongodb.net/?appName=cluster-name
DB_NAME=medicalreport

# Vector Database Configuration
VECTOR_DB_PATH=./data/vector-db

# FastAPI Configuration
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Gemini AI API Key (Required for translation and simplification)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Other AI provider keys (if needed in the future)
# OPENAI_API_KEY=your_openai_key_here
# HUGGINGFACE_API_KEY=your_huggingface_key_here
