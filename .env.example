# ============================================================================
# MEDICAL REPORT AI BACKEND - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and configure for your environment
#   cp .env.example .env
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB Connection String
# For MongoDB Atlas: mongodb+srv://username:password@cluster-name.mongodb.net/database
# For Local MongoDB: mongodb://localhost:27017
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/medicalreport?retryWrites=true&w=majority
DB_NAME=medicalreport

# ============================================================================
# VECTOR DATABASE CONFIGURATION
# ============================================================================

# ChromaDB persistent storage path
VECTOR_DB_PATH=./data/vector-db

# ============================================================================
# AI/ML SERVICES CONFIGURATION
# ============================================================================

# Google Gemini API Key (Required for text simplification, translation, RAG)
# Get your FREE API key from: https://makersuite.google.com/app/apikey
# If not set, system will gracefully fall back to original text
GEMINI_API_KEY=<your_gemini_api_key_here>

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================

# JWT Secret Key (for signing authentication tokens)
# IMPORTANT: Change to a strong random value in production!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<your-secret-key-change-in-production>

# JWT Token expiration time (hours)
ACCESS_TOKEN_EXPIRE_HOURS=24

# ============================================================================
# FASTAPI SERVER CONFIGURATION
# ============================================================================

# Server host (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0

# Server port
PORT=8000

# Debug mode (True for development, False for production)
DEBUG=False

# ============================================================================
# OPTIONAL: REDIS/CELERY (for background tasks)
# ============================================================================

# Redis connection URL (optional, for async task queue)
# REDIS_URL=redis://localhost:6379/0
